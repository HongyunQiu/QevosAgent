{
  "name": "qevosagent-desktop",
  "version": "0.1.0",
  "description": "QevosAgent Desktop App",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "setup":     "node scripts/setup_python.js",
    "build":       "electron-builder --win",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:dir":   "electron-builder --win --dir"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron":         "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId":       "com.qevosagent.desktop",
    "productName": "QevosAgent",
    "asar":        false,
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick":                        false,
      "allowToChangeInstallationDirectory": true,
      "perMachine":                      false,
      "deleteAppDataOnUninstall":        false
    },
    "files": [
      "**/*",
      "!scripts/**",
      "!dist/**"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
