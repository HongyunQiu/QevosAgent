{
  "name": "qevosagent-desktop",
  "version": "0.3.10",
  "description": "QevosAgent Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "setup": "node scripts/setup_python.js",
    "test": "node --test ./icon-path.test.js ./preserve-paths.test.js",
    "build": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:dir": "electron-builder --win --dir"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "rcedit": "^5.0.1"
  },
  "build": {
    "appId": "com.qevosagent.desktop",
    "productName": "QevosAgent",
    "asar": false,
    "afterPack": "./scripts/after-pack.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "extraResources": [
        {
          "from": "build/icon.ico",
          "to": "icon.ico"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "pkg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "pkg": {
      "installLocation": "/Applications",
      "scripts": "pkg-scripts"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": "always",
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "files": [
      "**/*",
      "!**/*.test.js",
      "!build/installer.nsh",
      "!build/preserve-paths.nsh",
      "!build/pkg-scripts/**",
      "!scripts/**",
      "!dist/**"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
