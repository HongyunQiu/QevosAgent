<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Thin page-load progress bar pinned to the top -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:max="100"
        android:visibility="gone"
        android:progressTint="@color/colorAccent" />

    <!-- 连接失败时的错误界面 -->
    <LinearLayout
        android:id="@+id/layoutError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="@color/white"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textSize="48sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="无法连接到 Agent"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请确认 QevosAgent 正在主机上运行，\n且手机与主机处于同一网络（或 ZeroTier）"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="36dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetry"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="重新连接"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:id="@+id/btnSettings"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:text="服务器设置" />

    </LinearLayout>

    <!-- Right-edge floating handle (draggable vertically); tap opens the action menu.
         Placed last so it floats above the error screen too (switch servers while disconnected). -->
    <FrameLayout
        android:id="@+id/edgeHandle"
        android:layout_width="26dp"
        android:layout_height="56dp"
        android:layout_gravity="end|top"
        android:alpha="0.4"
        android:background="@drawable/bg_edge_handle">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_handle"
            android:contentDescription="菜单" />

    </FrameLayout>

</FrameLayout>
