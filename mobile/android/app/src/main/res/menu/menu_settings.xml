<?xml version="1.0" encoding="utf-8"?>
<!-- Toolbar overflow menu for SettingsActivity. SAF-based config backup so
     users can survive an "adb install" that triggers the uninstall fallback
     (which wipes SharedPreferences). No storage permission needed — the
     system picker handles location entirely.

     NOTE: must use app:showAsAction (the AppCompat attr) instead of
     android:showAsAction. With the framework attribute alone, AppCompat may
     skip the overflow button entirely on some Material themes. -->
<menu xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto">
    <item
        android:id="@+id/action_export"
        android:title="导出配置"
        app:showAsAction="never" />
    <item
        android:id="@+id/action_import"
        android:title="导入配置"
        app:showAsAction="never" />
</menu>
