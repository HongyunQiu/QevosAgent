# LLM 服务配置（主 API）
OPENAI_BASE_URL=http://your-server:8000/v1

# 模型名称（可选）：若服务端只部署了一个模型，可省略，启动时自动检测
# OPENAI_MODEL=your-model-name

# API Key：本地/自建服务填 local 即可；OpenAI 官方填真实 key
OPENAI_API_KEY=local

# 备用 API（可选）：启动时探测主 API 失败会自动切到备用，本次 run 后续都用备用配置。
# 留空则不启用备用。三项必须同时配齐（base + key + model），因为不同 endpoint 的 model id 通常不一样。
# BACKUP_OPENAI_BASE_URL=https://api.openai.com/v1
# BACKUP_OPENAI_API_KEY=sk-...
# BACKUP_OPENAI_MODEL=gpt-4o-mini

# 顾问模型 1 / 2（可选）：仅供 openai_consult 工具按需咨询，不参与主备 fallback。
# 模型可在执行中用 openai_consult(question=..., advisor=1|2) 向更强模型征询独立意见。
# 每个顾问需配齐 base + model（key 本地服务可留空）。在看板「设置 → LLM 服务 → 顾问模型1/2」也可填。
# ADVISOR1_OPENAI_BASE_URL=https://api.openai.com/v1
# ADVISOR1_OPENAI_API_KEY=sk-...
# ADVISOR1_OPENAI_MODEL=gpt-4o
# Anthropic：base 填 https://api.anthropic.com/v1/，key 填 Anthropic key（sk-ant-...），model 填 claude-*。
# 工具检测到 anthropic.com 会自动改用原生 Anthropic SDK（功能最全）；否则走 OpenAI 兼容层。
# ADVISOR2_OPENAI_BASE_URL=https://api.anthropic.com/v1/
# ADVISOR2_OPENAI_API_KEY=sk-ant-...
# ADVISOR2_OPENAI_MODEL=claude-opus-4-8

# 实例昵称（可选）：显示在看板右上角的 “昵称:端口”，便于区分多个实例/窗口。
# 留空则只显示端口。仅作显示标签，不影响组网节点码。
# INSTANCE_NAME=

# HTTP 代理（可选）：访问外部 LLM API（OpenAI / Anthropic 等）时需要。
# 注意：
# 1) httpx 默认会读系统代理，但 Linux+GNOME 下会拿到 'socks://...' 这种 httpx 不支持的 scheme，
#    导致启动报 'Unknown scheme for proxy URL'。本项目已关掉自动探测，只信任下面这两个变量。
# 2) 因此 Ubuntu 在「设置 → 网络 → 网络代理」GUI 里配的代理对本项目不生效，必须在这里显式设置
#    （或在 shell 中 export）。
# 3) base_url 命中本地 / 内网时会自动跳过代理，无需手配：
#    回环（127.0.0.1, ::1, localhost）、RFC1918 私有段（192.168/10/172.16-31）、
#    链路本地（169.254/16）、常见内网域名后缀（.local / .lan / .internal）。
# 4) 如果你有上面规则覆盖不到的内网域名（如公司 *.corp.example.com），用 NO_PROXY 显式追加：
#    NO_PROXY=corp.example.com,intranet.foo.org
# HTTPS_PROXY=http://127.0.0.1:7897
# HTTP_PROXY=http://127.0.0.1:7897
# NO_PROXY=

# Optional runtime knobs
# MAX_ITERS=40
# RUNS_DIR=./runs
# AGENT_SNAPSHOT=./agent_snapshot_meta.json
# AUTO_REMEMBER_ON_DONE=1
# AUTO_SAVE_SNAPSHOT_ON_EXIT=1
