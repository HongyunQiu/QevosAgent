# LLM 服务配置（必填）
OPENAI_BASE_URL=http://your-server:8000/v1
OPENAI_MODEL=your-model-name

# API Key：本地/自建服务填 local 即可；OpenAI 官方填真实 key
OPENAI_API_KEY=local

# Optional runtime knobs
# MAX_ITERS=40
# RUNS_DIR=./runs
# AGENT_SNAPSHOT=./agent_snapshot_meta.json
# AUTO_REMEMBER_ON_DONE=1
# AUTO_SAVE_SNAPSHOT_ON_EXIT=1
